---
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allArticles = await getCollection('articles');
  const categories = [...new Set(allArticles.map(post => post.data.category))];
  
  return categories.map(category => ({
    params: { category: category.toLowerCase().replace(' ', '-') },
    props: { category, articles: allArticles.filter(post => post.data.category === category) },
  }));
}

const { category, articles } = Astro.props;
---

<html lang="en" class="bg-[#0F1014] text-[#A1A1AA]">
<body class="font-sans antialiased">
    <nav class="border-b border-[#3F3F46] px-12 py-5 bg-[#0F1014]">
        <a href="/" class="text-white font-bold text-xl">AETHER</a>
    </nav>

    <main class="max-w-[1440px] mx-auto px-12 py-16">
        <h1 class="text-5xl font-extrabold text-white mb-12 capitalize">{category}</h1>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            {articles.map(post => (
                <a href={`/articles/${post.id.replace('.md', '')}`} class="bg-[#18181B] border border-[#3F3F46] rounded-xl overflow-hidden hover:border-purple-600 transition-all">
                    <div class="h-48 w-full bg-[#0F1014]">
                        <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover" />
                    </div>
                    <div class="p-6">
                        <h4 class="text-xl font-bold text-white">{post.data.title}</h4>
                        <p class="text-sm mt-4">{post.data.date.toDateString()}</p>
                    </div>
                </a>
            ))}
        </div>
    </main>
</body>
</html>